#!/usr/bin/env python3
import json
import os
import shlex
import shutil
import subprocess
import sys
import urllib.error
import urllib.request
from pathlib import Path

API = 'http://127.0.0.1:8093/api/sidecars'
CAPABILITIES_API = 'http://127.0.0.1:8093/api/capabilities'
EVOLUTION_API = 'http://127.0.0.1:8093/api/evolution'
CONFIG = Path('/root/.nanobot/sidecars.json')
CAPABILITIES_CONFIG = Path('/root/.nanobot/capabilities.json')
EVOLUTION_CONFIG = Path('/root/.nanobot/evolution.json')
STACK_TARGET = 'nanobot-stack.target'
RESTART_ORDER = [
    'podman-public-rule',
    'rss',
    'qq',
    'reflexio',
    'obp',
    'lof',
    'notify',
    'nanobot',
]
STOP_ORDER = list(reversed(RESTART_ORDER))
RUST_TARGETS = [
    '/root/.nanobot/workspace/skills/qdii-monitor/lof-sidecar-rs/target',
    '/root/.nanobot/workspace/skills/notify-sidecar-rs/target',
    '/root/qq-sidecar-rs/target',
    '/root/nanobot-reflexio-rs/target',
    '/root/obp-rs/target',
]


def load_config():
    return json.loads(CONFIG.read_text())


def load_api():
    with urllib.request.urlopen(API, timeout=6) as resp:
        return json.loads(resp.read().decode('utf-8'))


def load_capabilities_config():
    if CAPABILITIES_CONFIG.exists():
        return json.loads(CAPABILITIES_CONFIG.read_text())
    return []


def load_capabilities_api():
    with urllib.request.urlopen(CAPABILITIES_API, timeout=6) as resp:
        return json.loads(resp.read().decode('utf-8'))


def load_evolution_api():
    with urllib.request.urlopen(EVOLUTION_API, timeout=6) as resp:
        return json.loads(resp.read().decode('utf-8'))


def load_evolution_config():
    if EVOLUTION_CONFIG.exists():
        return json.loads(EVOLUTION_CONFIG.read_text())
    return []


def by_id():
    return {item.get('id'): item for item in load_config()}


def config_by_id(sidecar_id):
    cfg = by_id().get(sidecar_id)
    if not cfg:
        raise SystemExit(f'unknown sidecar id: {sidecar_id}')
    return cfg


def unit_for(cfg):
    unit = (cfg.get('unit') or '').strip()
    if not unit:
        raise SystemExit(f"{cfg.get('id')} has no systemd unit")
    return unit


def run(args, check=True, capture=False):
    return subprocess.run(
        args,
        check=check,
        text=True,
        stdout=subprocess.PIPE if capture else None,
        stderr=subprocess.PIPE if capture else None,
    )


def is_active(unit):
    p = run(['systemctl', 'is-active', unit], check=False, capture=True)
    return (p.stdout or p.stderr or '').strip() or 'unknown'


def ordered_configs(order):
    items = by_id()
    seen = set()
    result = []
    for sidecar_id in order:
        cfg = items.get(sidecar_id)
        if cfg and cfg.get('unit'):
            result.append(cfg)
            seen.add(sidecar_id)
    for cfg in load_config():
        if cfg.get('id') not in seen and cfg.get('unit'):
            result.append(cfg)
    return result


def status():
    data = load_api()
    summary = data.get('summary', {})
    print(f"Sidecars: {summary.get('healthy', 0)}/{summary.get('total', 0)} healthy @ {data.get('now', '-')}")
    print(f"{'id':<20} {'ok':<4} {'unit':<10} {'port':<6} {'public':<6} {'check':<14} active_since")
    for item in data.get('items', []):
        ok = 'yes' if item.get('ok') else 'no'
        unit = item.get('unit_status') or '-'
        port = str(item.get('port') or '-')
        public = 'yes' if item.get('public') else 'no'
        check = item.get('check_status') or '-'
        active = item.get('active_since') or '-'
        print(f"{item.get('id','-'):<20} {ok:<4} {unit:<10} {port:<6} {public:<6} {check:<14} {active}")
        for err in item.get('recent_errors') or []:
            print(f"  warning: {err}")


def urls(arg='all'):
    configs = load_config() if arg == 'all' else [config_by_id(arg)]
    for cfg in configs:
        value = cfg.get('homepage_url') or cfg.get('check_url') or '-'
        print(f"{cfg.get('id'):<20} {value}")


def units():
    for cfg in load_config():
        print(f"{cfg.get('id'):<20} {cfg.get('unit') or '-'}")


def capabilities(raw=False):
    try:
        data = load_capabilities_api()
    except Exception:
        items = load_capabilities_config()
        data = {
            'now': 'offline-config',
            'summary': {
                'total': len(items),
                'enabled': sum(1 for item in items if item.get('enabled')),
                'healthy': 0,
                'degraded': 0,
            },
            'items': items,
        }
    if raw:
        print(json.dumps(data, ensure_ascii=False, indent=2))
        return
    summary = data.get('summary', {})
    print(
        'Capabilities: '
        f"{summary.get('healthy', 0)}/{summary.get('total', 0)} healthy, "
        f"{summary.get('enabled', 0)} enabled @ {data.get('now', '-')}"
    )
    print(f"{'id':<24} {'kind':<10} {'service':<12} {'ok':<4} name")
    for item in data.get('items', []):
        ok = 'yes' if item.get('ok') else ('-' if 'ok' not in item else 'no')
        print(
            f"{item.get('id','-'):<24} "
            f"{item.get('kind','-'):<10} "
            f"{str(item.get('service_id') or '-'):<12} "
            f"{ok:<4} "
            f"{item.get('name','-')}"
        )


def evolution(raw=False):
    try:
        data = load_evolution_api()
    except Exception:
        items = load_evolution_config()
        data = {
            'now': 'offline-config',
            'summary': {'total': len(items), 'recent_7d': 0, 'categories': {}},
            'items': items,
        }
    if raw:
        print(json.dumps(data, ensure_ascii=False, indent=2))
        return
    summary = data.get('summary', {})
    print(
        'Evolution: '
        f"{summary.get('total', 0)} records, "
        f"{summary.get('recent_7d', 0)} in 7d @ {data.get('now', '-')}"
    )
    print(f"{'date':<12} {'category':<12} title")
    for item in data.get('items', [])[:10]:
        print(f"{item.get('date','-'):<12} {item.get('category','-'):<12} {item.get('title','-')}")


def stack():
    print(f'{STACK_TARGET}: {is_active(STACK_TARGET)}')
    run(['systemctl', 'list-dependencies', '--plain', '--no-pager', STACK_TARGET], check=False)


def log_args(cfg, tail, follow):
    unit = cfg.get('unit')
    cmd = cfg.get('logs_command') or ''
    parts = shlex.split(cmd)
    if len(parts) >= 3 and parts[:2] == ['podman', 'logs']:
        container = parts[-1]
        args = ['podman', 'logs', '--tail', str(tail)]
        if follow:
            args.append('-f')
        args.append(container)
        return args
    if unit:
        args = ['journalctl', '-u', unit, '-n', str(tail), '--no-pager']
        if follow:
            args.append('-f')
        return args
    raise SystemExit(f"{cfg.get('id')} has no logs command")


def logs(sidecar_id, tail=120, follow=False):
    cfg = config_by_id(sidecar_id)
    args = log_args(cfg, tail, follow)
    print('+ ' + shlex.join(args))
    subprocess.call(args)


def logcmd(sidecar_id, tail=120, follow=True):
    cfg = config_by_id(sidecar_id)
    print(shlex.join(log_args(cfg, tail, follow)))


def restart_one(sidecar_id, dry_run=False):
    cfg = config_by_id(sidecar_id)
    unit = unit_for(cfg)
    cmd = ['systemctl', 'restart', unit]
    print('+ ' + shlex.join(cmd))
    if not dry_run:
        run(cmd)
        print(f'restarted {sidecar_id}: {unit}')


def restart_all(dry_run=False):
    for cfg in ordered_configs(RESTART_ORDER):
        unit = unit_for(cfg)
        cmd = ['systemctl', 'restart', unit]
        print('+ ' + shlex.join(cmd))
        if not dry_run:
            run(cmd)
    if not dry_run:
        print('waiting for services...')
        run(['sleep', '3'], check=False)
        status()


def start_all():
    run(['systemctl', 'start', STACK_TARGET])
    print(f'started {STACK_TARGET}')


def stop_all(yes=False):
    if not yes:
        raise SystemExit('refusing to stop the stack without --yes')
    for cfg in ordered_configs(STOP_ORDER):
        unit = unit_for(cfg)
        cmd = ['systemctl', 'stop', unit]
        print('+ ' + shlex.join(cmd))
        run(cmd, check=False)


def disk_percent(path='/'):
    total, used, free = shutil.disk_usage(path)
    return int(used * 100 / total), total, used, free


def mem_available_mb():
    data = {}
    for line in Path('/proc/meminfo').read_text().splitlines():
        key, rest = line.split(':', 1)
        data[key] = int(rest.strip().split()[0]) // 1024
    return data.get('MemAvailable', 0), data.get('MemTotal', 0)


def doctor():
    issues = []
    print('== API ==')
    try:
        data = load_api()
        summary = data.get('summary', {})
        print(f"sidecars {summary.get('healthy', 0)}/{summary.get('total', 0)} healthy @ {data.get('now', '-')}")
        for item in data.get('items', []):
            if not item.get('ok'):
                issues.append(f"unhealthy: {item.get('id')} {item.get('check_status')} {item.get('error') or ''}")
            for err in item.get('recent_errors') or []:
                issues.append(f"recent warning: {item.get('id')} {err}")
    except Exception as exc:
        issues.append(f'api unavailable: {exc}')
        print(f'api unavailable: {exc}')

    print('\n== systemd ==')
    target_state = is_active(STACK_TARGET)
    print(f'{STACK_TARGET}: {target_state}')
    if target_state != 'active':
        issues.append(f'{STACK_TARGET} is {target_state}')
    for cfg in load_config():
        unit = cfg.get('unit')
        if not unit:
            continue
        state = is_active(unit)
        print(f'{cfg.get("id"):<20} {state:<10} {unit}')
        if state not in ('active',):
            issues.append(f'{unit} is {state}')

    print('\n== resources ==')
    pct, total, used, free = disk_percent('/')
    print(f'disk /: {pct}% used')
    if pct >= 90:
        issues.append(f'disk / high: {pct}%')
    avail, total_mem = mem_available_mb()
    print(f'memory available: {avail} MiB / {total_mem} MiB')
    if avail < 256:
        issues.append(f'memory available low: {avail} MiB')

    print('\n== build cache ==')
    cache_found = False
    for path in RUST_TARGETS:
        if os.path.exists(path):
            cache_found = True
            print(f'present: {path}')
    if not cache_found:
        print('rust target caches: clean')

    if issues:
        print('\n== issues ==')
        for issue in issues:
            print(f'- {issue}')
        raise SystemExit(1)
    print('\nOK: stack looks healthy')


def usage():
    print('usage: sidecarctl <command> [args]')
    print('commands:')
    print('  status | list')
    print('  capabilities [--json]')
    print('  evolution [--json]')
    print('  doctor')
    print('  stack')
    print('  units')
    print('  url <id|all>')
    print('  logs <id> [--tail N] [--follow|-f]')
    print('  logcmd <id> [--tail N] [--follow|--no-follow]')
    print('  restart <id|all> [--dry-run]')
    print('  start all')
    print('  stop all --yes')
    print('ids: ' + ', '.join(item.get('id', '-') for item in load_config()))


def parse_tail(args, default=120):
    if '--tail' in args:
        idx = args.index('--tail')
        try:
            return int(args[idx + 1])
        except (IndexError, ValueError):
            raise SystemExit('--tail requires an integer')
    return default


def main():
    args = sys.argv[1:]
    if not args:
        return status()
    cmd = args[0]
    rest = args[1:]
    if cmd in ('status', 'list'):
        return status()
    if cmd in ('capabilities', 'caps'):
        return capabilities('--json' in rest)
    if cmd in ('evolution', 'evo'):
        return evolution('--json' in rest)
    if cmd == 'doctor':
        return doctor()
    if cmd == 'stack':
        return stack()
    if cmd == 'units':
        return units()
    if cmd == 'url' and len(rest) == 1:
        return urls(rest[0])
    if cmd == 'url' and not rest:
        return urls('all')
    if cmd == 'logs' and rest:
        sidecar_id = rest[0]
        tail = parse_tail(rest[1:])
        follow = '--follow' in rest[1:] or '-f' in rest[1:]
        return logs(sidecar_id, tail, follow)
    if cmd == 'logcmd' and rest:
        sidecar_id = rest[0]
        tail = parse_tail(rest[1:])
        follow = '--no-follow' not in rest[1:]
        return logcmd(sidecar_id, tail, follow)
    if cmd == 'restart' and len(rest) >= 1:
        dry_run = '--dry-run' in rest
        target = rest[0]
        if target == 'all':
            return restart_all(dry_run)
        return restart_one(target, dry_run)
    if cmd == 'start' and rest == ['all']:
        return start_all()
    if cmd == 'stop' and rest and rest[0] == 'all':
        return stop_all('--yes' in rest)
    usage()
    raise SystemExit(2)


if __name__ == '__main__':
    main()

[
  {
    "id": "ops-health",
    "name": "运维问答",
    "description": "内存、服务、cron、LOF 状态走真实本地数据，避免让 LLM 猜系统状态。",
    "category": "运维",
    "kind": "script",
    "service_id": "nanobot",
    "entry_url": "/sidecars",
    "enabled": true,
    "trigger_phrases": ["内存怎么样", "服务状态", "cron 任务怎么样", "LOF 有机会吗"],
    "commands": [
      {
        "label": "内存报告",
        "command": "/root/nanobot/scripts/memory_report.sh"
      },
      {
        "label": "服务总览",
        "command": "sidecarctl status"
      }
    ],
    "data_paths": ["/root/.nanobot/data/ops"],
    "tags": ["ops", "direct-reply", "read-only"],
    "mcp_tools": [],
    "notes": "适合做 nanobot 的快捷回复和健康自检底座。"
  },
  {
    "id": "knowledge-inbox",
    "name": "知识收件箱",

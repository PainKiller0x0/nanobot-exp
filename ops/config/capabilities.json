  {
    "id": "decision-assistant",
    "name": "个人决策助手",
    "description": "聚合系统、文章、LOF、任务数据，回答“今天先看什么 / 下一步做什么”。",
    "category": "决策",
    "kind": "skill",
    "service_id": "lof",
    "entry_url": "/",
    "enabled": true,
    "trigger_phrases": ["今天先看什么", "今天怎么安排", "有什么建议"],
    "commands": [
      {
        "label": "生成决策摘要",
        "command": "python /root/.nanobot/workspace/skills/personal-ops-assistant/ops_summary.py decision"
      }
    ],
    "data_paths": ["/root/.nanobot/data/personal-ops-assistant"],
    "tags": ["decision", "dashboard", "summary"],
    "mcp_tools": [],
    "notes": "更像 Hermes 的 user-facing routine，不应该散落在多个脚本里。"
  },
  {
    "id": "rss-article-radar",
    "name": "文章雷达",
    "description": "微信文章、鸭哥 AI 要闻、Markdown 预览和广告过滤，统一经 8093/rss 查看。",
    "category": "信息",
    "kind": "sidecar",
    "service_id": "rss",
    "entry_url": "/rss/",

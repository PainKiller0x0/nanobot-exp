  {
    "id": "lof-monitor",
    "name": "LOF 估值雷达",
    "description": "QDII/LOF 实时估值、溢价、历史溢价和推送报告。",
    "category": "投资",
    "kind": "sidecar",
    "service_id": "lof",
    "entry_url": "/lof",
    "enabled": true,
    "trigger_phrases": ["LOF 有机会吗", "LOF 看板", "估值刷新"],
    "commands": [
      {
        "label": "手动刷新",
        "command": "curl -fsS -X POST http://127.0.0.1:8093/api/run -H 'content-type: application/json' -d '{\"tag\":\"manual\"}'"
      },
      {
        "label": "LOF 日志",
        "command": "journalctl -u lof-sidecar.service -f"
      }
    ],
    "data_paths": ["/root/.nanobot/workspace/skills/qdii-monitor"],
    "tags": ["finance", "sidecar", "report"],
    "mcp_tools": ["lof.refresh", "lof.board", "lof.report"],
    "notes": "已实现交易时段高频刷新，定时任务发送前可触发刷新再读缓存。"
  },

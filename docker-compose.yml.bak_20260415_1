services:
  nanobot:
    build: .
    container_name: nanobot-cage
    user: root
    privileged: true
    ports:
      - "8080:8080"
    volumes:
      - /root/.nanobot:/root/.nanobot
      - /root/nanobot:/app
      - /etc/localtime:/etc/localtime:ro
      - /var/run/docker.sock:/var/run/docker.sock
    restart: always
    environment:
      - NANOBOT_CONFIG=/root/.nanobot/config.json
      - TZ=Asia/Shanghai
      - NANOBOT_REFLEXIO_ENABLED=true
      - REFLEXIO_URL=http://reflexio-sidecar:8081
      - REFLEXIO_AGENT_VERSION=nanobot-main
      - REFLEXIO_SOURCE=nanobot
    networks:
      - bot-net
    deploy:
      resources:
        limits:
          memory: 1024M

  wechat-rss-sidecar:
    image: python:3.11-slim
    container_name: wechat-rss-sidecar
    user: root
    working_dir: /root/.nanobot/workspace/wechat_rss_service
    command: sh -lc "WECHAT_RSS_HOST=0.0.0.0 WECHAT_RSS_PORT=8091 python3 app.py"
    ports:
      - "8091:8091"
    volumes:
      - /root/.nanobot:/root/.nanobot
      - /root/nanobot:/root/nanobot:ro
    restart: always
    networks:
      - bot-net

  reflexio-sidecar:
    build:
      context: /root/.nanobot/workspace/reflexio
      dockerfile: Dockerfile
    container_name: reflexio-sidecar
    user: root
    environment:
      - TZ=Asia/Shanghai
      - IS_TEST_ENV=false
      - DEBUG_LOG_TO_CONSOLE=false
      - OPENAI_API_KEY=sk-aaqoholoymvwuqtlgtbwplxmpcwyhdptwyyoborrpaiufuze
      - MOCK_LLM_RESPONSE=false
      - LOCAL_STORAGE_PATH=/root/.reflexio/data
      - SQLITE_FILE_DIRECTORY=/root/.reflexio/data
      - MINIMAX_API_KEY=sk-cp-rCGw77WLKRvlXVxokJXVuXbyTGSJrnwO74JxI75xBEDuhRl18PnVYWtE3zZD2SBNE-1oIB53_TmBO3KOUksjOiItvzOpeiFKGnkkPIJrQStQHww_TT-YJEY
      - REFLEXIO_SILICONFLOW_EMBEDDING_ENABLED=true
      - REFLEXIO_SILICONFLOW_EMBEDDING_URL=https://api.siliconflow.cn/v1/embeddings
      - REFLEXIO_SILICONFLOW_EMBEDDING_MODEL=BAAI/bge-m3
      - REFLEXIO_SILICONFLOW_EMBEDDING_API_KEY=sk-aaqoholoymvwuqtlgtbwplxmpcwyhdptwyyoborrpaiufuze
    volumes:
      - /root/.nanobot/reflexio:/root/.reflexio
      - /root/.nanobot/workspace/reflexio:/root/.nanobot/workspace/reflexio
    restart: always
    networks:
      - bot-net

  browserless:
    image: browserless/chrome:latest
    container_name: browserless
    restart: always
    environment:
      - MAX_CONCURRENT_SESSIONS=5
      - MAX_QUEUE_LENGTH=10
      - CONNECTION_TIMEOUT=60000
    networks:
      - bot-net
    deploy:
      resources:
        limits:
          memory: 1024M

networks:
  bot-net:
    driver: bridge
